{
  "name": "navpahal-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format:check": "prettier --check \"*.{ts,tsx,json,mjs}\" \"app/**/*.{ts,tsx,css}\" \"docs/**/*.md\" \"src/**/*.{ts,tsx,css,json}\" \"e2e/**/*.ts\"",
    "format": "prettier --write \"*.{ts,tsx,json,mjs}\" \"app/**/*.{ts,tsx,css}\" \"docs/**/*.md\" \"src/**/*.{ts,tsx,css,json}\" \"e2e/**/*.ts\"",
    "lint": "eslint app/ src/ e2e/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "clean": "rimraf dist .next out",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "check-all": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next": "^16.0.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@next/eslint-plugin-next": "^16.2.11",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.4",
    "prettier": "^3.9.5",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
